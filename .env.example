# Copy to .env.local (git-ignored) and fill in real values. All are optional:
# nothing is injected unless the corresponding variable is set, so the static
# export never ships empty tags or fake IDs.

# Google Analytics 4 — inject gtag.js only when this measurement ID is present.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Cloudflare Web Analytics — inject the beacon only when this token is present.
# Set in Cloudflare Pages → Settings → Environment variables (Production + Preview) so builds embed the script.
NEXT_PUBLIC_CLOUDFLARE_ANALYTICS_TOKEN=

# Search engine site verification meta tags (optional; HTML-file verification also works).
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=
NEXT_PUBLIC_YANDEX_SITE_VERIFICATION=

# Set to 1 to skip the IndexNow submission step during `npm run deploy`.
SKIP_INDEXNOW=
